# ============================================================
#  GHN Dashboard — biến môi trường (KHÔNG commit file .env thật)
#  Copy file này thành .env và điền giá trị thật.
# ============================================================

# --- NextAuth ---
# URL công khai của site (đúng domain bạn deploy, có https)
NEXTAUTH_URL=https://dashboard.ghn.vn
# Chuỗi bí mật ngẫu nhiên. Tạo bằng: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Google OAuth (đăng nhập) ---
# Lấy từ Google Cloud Console > APIs & Services > Credentials > OAuth client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Chỉ cho phép email thuộc domain này đăng nhập
ALLOWED_EMAIL_DOMAIN=ghn.vn

# --- Google Sheets (nguồn dữ liệu, service account) ---
# ID của Google Sheet (phần giữa /d/ và /edit trong URL). CHỈ sheet này được phép đọc.
GOOGLE_SHEET_ID=
# --- Cách 1 (DỄ NHẤT): trỏ tới file JSON key tải từ Google ---
# Lưu file vào thư mục dự án, ví dụ đặt tên service-account.json (đã được .gitignore).
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=service-account.json

# --- Cách 2: dán trực tiếp email + private key (chỉ dùng nếu không dùng Cách 1) ---
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Tuỳ chọn ---
# Chu kỳ server đọc lại Sheet (ms). Mặc định 20000 = 20 giây.
REFRESH_MS=20000
# Tên các tab trong Sheet (đổi nếu sheet của bạn đặt tên khác)
SHEET_TAB_LEADTIME=Leadtime
SHEET_TAB_COST=Cost
SHEET_TAB_PROD=Productivity
SHEET_TAB_NOTES=Notes
